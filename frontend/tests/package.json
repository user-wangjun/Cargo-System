{
  "name": "cargo-frontend-tests",
  "type": "module",
  "scripts": {
    "test": "vitest --run --exclude \"{e2e/**,e2e-live/**}\"",
    "test:e2e": "playwright test",
    "test:e2e:live": "playwright test -c playwright.live.config.js",
    "test:all": "npm run test && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "fast-check": "^3.0.0",
    "jsdom": "^29.0.2",
    "vitest": "^1.0.0"
  }
}
